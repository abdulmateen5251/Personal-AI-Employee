#!/usr/bin/env bash
set -euo pipefail

# Blocks pushes containing likely secrets.
# Scans commit diffs being pushed (not full repo history every time).

SECRET_PATTERN='(BEGIN[[:space:]]+PRIVATE[[:space:]]+KEY|GOOGLE_SERVICE_ACCOUNT_INFO|SENDER_PASSWORD|API[_-]?KEY|SECRET[_-]?KEY|ACCESS[_-]?TOKEN|REFRESH[_-]?TOKEN|client_secret|private_key|password[[:space:]]*=)'
BLOCKED_PATH_PATTERN='(^|/)\.env($|\.)|(^|/)token\.json$|(^|/)credentials\.json$|(^|/)linkedin_token\.json$|(^|/)calendar_token\.json$|(^|/)\.pem$|(^|/)\.p12$'

has_error=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # New branch push
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # 1) Block suspicious file paths
  if git diff --name-only "$range" | grep -Eiq "$BLOCKED_PATH_PATTERN"; then
    echo "[SECURITY] Push blocked: sensitive file path detected in commits being pushed."
    git diff --name-only "$range" | grep -Ei "$BLOCKED_PATH_PATTERN" || true
    has_error=1
  fi

  # 2) Block suspicious content in diffs
  if git log -p "$range" -- . | grep -Eiq "$SECRET_PATTERN"; then
    echo "[SECURITY] Push blocked: potential secret detected in commit diff."
    echo "[SECURITY] Matching lines:"
    git log -p "$range" -- . | grep -Ein "$SECRET_PATTERN" | head -30 || true
    has_error=1
  fi
done

if [[ "$has_error" -ne 0 ]]; then
  echo "[SECURITY] Resolve secrets/remove sensitive files, then push again."
  exit 1
fi

exit 0
